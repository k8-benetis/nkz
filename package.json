{
  "name": "nekazari-monorepo",
  "private": true,
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "validate:i18n": "./scripts/validate-i18n-json.sh",
    "test:e2e": "pnpm --filter nekazari-frontend run test:e2e",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "lint-staged": "^15.2.10",
    "turbo": "^2.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.py": [
      "ruff check --fix",
      "ruff format"
    ]
  }
}